---
import '../styles/global.css';
import FaviconLinks from '../components/FaviconLinks.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SnakeGridBackground from '../components/SnakeGridBackground.astro';
import SiteNav from '../components/SiteNav.astro';

const javaRoadItems = [
  {
    title: 'Ai Agent',
    date: '阶段 01',
    description: '语法、集合、异常、泛型和常用 API 的系统复盘。',
    cover: 'code',
    coverImage: '/images/ai-agent-cover-macaron.png',
    coverTitle: '1.0Agent',
    href: 'https://ncnr64zcbo47.feishu.cn/wiki/OB0jw1h5Sis8Yskn7p6czGYOnae?from=from_copylink',
    links: ['Notes'],
  },
  {
    title: 'JVM 与并发',
    date: '阶段 02',
    description: '类加载、内存模型、垃圾回收和线程协作机制。',
    cover: 'timeline',
    links: ['Notes'],
  },
  {
    title: 'Spring Boot',
    date: '阶段 03',
    description: 'Web 服务、配置管理、参数校验和统一异常处理。',
    cover: 'dashboard',
    links: ['Code'],
  },
  {
    title: 'MyBatis',
    date: '阶段 04',
    description: 'SQL 映射、动态查询、分页和事务边界。',
    cover: 'paper',
    links: ['Code'],
  },
  {
    title: 'Redis 缓存',
    date: '阶段 05',
    description: '缓存策略、分布式锁、热点数据和过期策略。',
    cover: 'chart',
    links: ['Notes'],
  },
  {
    title: 'Java 基础',
    date: '阶段 06',
    description: 'RocketMQ/Kafka 的削峰、异步解耦与可靠投递。',
    cover: 'terminal',
    coverImage: '/images/java-basics-cover-macaron.png',
    coverTitle: '2.1Java基础',
    href: 'https://ncnr64zcbo47.feishu.cn/wiki/D8gWwsK1LiYjL6kYa0ZcUWlmnUe?from=from_copylink',
    links: ['Notes'],
  },
  {
    title: 'Java 集合',
    date: '阶段 07',
    description: '系统学习 List、Set、Map 等集合体系、常用实现与适用场景。',
    cover: 'code',
    coverImage: '/images/java-collections-cover-macaron.png',
    coverTitle: '2.2Java集合',
    href: 'https://ncnr64zcbo47.feishu.cn/wiki/SjyDwJISQid2QQklRQccKLHjnNe?from=from_copylink',
    links: ['Code'],
  },
  {
    title: 'Java 并发',
    date: '阶段 08',
    description: '系统学习线程、线程池、锁机制与并发编程模型。',
    cover: 'code',
    coverImage: '/images/java-concurrency-cover-macaron.png',
    coverTitle: '2.3Java并发',
    href: 'https://ncnr64zcbo47.feishu.cn/wiki/BBhYwB3pniNX7KkT0P1cMuALnne?from=from_copylink',
    links: ['Docs'],
  },
  {
    title: '性能压测',
    date: '阶段 09',
    description: '接口压测、瓶颈定位、线程池和数据库调优。',
    cover: 'chart',
    links: ['Blog'],
  },
  {
    title: '项目复盘',
    date: '阶段 10',
    description: '整理需求拆解、技术选型、问题记录和交付复盘。',
    cover: 'profile',
    links: ['Blog'],
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="壹贰叁218 的学习之路展示页。" />
    <FaviconLinks />
    <title>学习之路 | coderxiaoliao</title>
  </head>
  <body>
    <SnakeGridBackground />
    <SiteNav active="javaRoad" />

    <main class="projects-shell java-road-shell">
      <header class="projects-hero">
        <h1>记录我的学习之路</h1>
      </header>

      <section class="projects-grid java-road-grid" aria-label="学习之路列表">
        {javaRoadItems.map((item) => (
          <ProjectCard item={item} variant="tile" hideActions hideMeta />
        ))}
      </section>
    </main>
  </body>
</html>
