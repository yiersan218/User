---
import '../styles/global.css';
import FaviconLinks from '../components/FaviconLinks.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SnakeGridBackground from '../components/SnakeGridBackground.astro';
import SiteNav from '../components/SiteNav.astro';

const projects = [
  {
    title: '大语言模型推理服务平台',
    date: '2026年3月 - 至今',
    description: '基于 SGLang 的推理框架与服务平台，围绕吞吐、成本和稳定性搭建大模型推理服务。',
    cover: 'dashboard',
    links: ['GitHub', 'Demo'],
  },
  {
    title: '🤐大营销运营中心-抽奖及返利服务',
    date: '2025年6月 - 2026年1月',
    description: '基于 DDD 分层架构构建营销抽奖系统，通过规则链与规则树编排抽奖前置过滤、过程决策和结果发放，解耦活动装配、奖品发放、签到返利、积分账户与 SKU 兑换等核心流程，并融入降级、限流、熔断等分布式治理能力。',
    cover: 'terminal',
    coverImage: '/images/big-market-lottery-cover-no-robot.png',
    href: 'https://ncnr64zcbo47.feishu.cn/wiki/GqV6wfpKriv5CIkrPUDcH04enJe',
    links: ['GitHub', 'Docs'],
  },
  {
    title: '😤Ai agent脚手架',
    date: '2024年3月 - 2025年3月',
    description: '遵循 DDD 分层架构进行开发，核心采用了组合模式构建智能体的执行规则树（Agentflow 工作流），并结合策略模式（MCP 工具创建策略和工作流节点选择策略）、工厂模式（创建不同类型的 Agent 和 Tool 节点）、以及规则树设计模式（处理节点间的上下文传递）来处理具体流程细节。',
    cover: 'chart',
    coverImage: '/images/ai-agent-scaffold-cover-v3.png',
    links: ['GitHub', 'Blog'],
  },
  {
    title: '个人主页模板',
    date: '2025年10月',
    description: '当前网站的静态主页模板，使用 Astro、React 和 Tailwind CSS 构建并部署到 Cloudflare Pages。',
    cover: 'profile',
    links: ['GitHub', 'Docs'],
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="壹贰叁218 的项目实践展示页。" />
    <FaviconLinks />
    <title>项目实践 | coderxiaoliao</title>
  </head>
  <body>
    <SnakeGridBackground />
    <SiteNav active="projects" />

    <main class="projects-shell projects-shell-wide">
      <header class="projects-hero">
        <h1>查看我的项目实践</h1>
      </header>

      <section class="projects-grid projects-grid-strip projects-grid-four" aria-label="项目实践列表">
        {projects.map((project) => (
          <ProjectCard item={project} variant="strip" />
        ))}
      </section>
    </main>
  </body>
</html>
